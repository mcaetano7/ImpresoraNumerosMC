# Renombrá este archivo a ".env" y completá con tus datos de conexión
# NO subas el archivo .env a GitHub (ya está en .gitignore)

DB_HOST=tu-host-de-base-de-datos     # Ej: mysql.railway.internal o xxx.mysql.pythonanywhere.com
DB_PORT=3306                          # Puerto MySQL (3306 por defecto)
DB_USER=tu-usuario
DB_PASS=tu-contraseña
DB_NAME=ImpresoraNumerosMC
